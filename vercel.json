{
  "outputDirectory": "dist",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/sitemap.xml", "dest": "/sitemap.xml" },
    { "src": "/robots.txt", "dest": "/robots.txt" },
    { "src": "/(.*\\.(ico|png|jpg|jpeg|svg|css|js|json|woff|woff2|webmanifest|txt|xml|html))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
